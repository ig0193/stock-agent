# Copy this file to `.env` and fill in a credential. The app auto-loads `.env`.
# .env is gitignored — your key will NOT be committed.

# Use ONE of the following:

# (a) Standard API key (supported, billed via console.anthropic.com):
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# (b) Claude Code OAuth token (uses your Claude subscription; unofficial path).
#     If set, this takes precedence over ANTHROPIC_API_KEY.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-token-here

# Optional overrides:
# STOCK_AGENT_MODEL=claude-sonnet-4-6
# STOCK_AGENT_LOG_LEVEL=INFO   # set DEBUG for per-fetch detail
